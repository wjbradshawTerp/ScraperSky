TWITTER_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_BEARER_TOKEN=Bearer xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_CSRF_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

SCROLL_DELAY=2

HOST_OUTPUT_DIR=./data
CONTAINER_OUTPUT_DIR=/app/data
OUTPUT_DIR=/app/data
TIMEZONE=America/New_York   # Set the timezone for timestamping output files from ZoneInfo

PLATFORM=twitter
MODE=follows